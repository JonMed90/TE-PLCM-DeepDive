model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Calendar

	annotation PBI_QueryGroupOrder = 0

queryGroup Inventory

	annotation PBI_QueryGroupOrder = 3

queryGroup Sales/Demand

	annotation PBI_QueryGroupOrder = 4

queryGroup 'PLCM RACI Playbook'

	annotation PBI_QueryGroupOrder = 5

queryGroup Products

	annotation PBI_QueryGroupOrder = 4

annotation PBI_QueryOrder = ["Historical Sales","Dim_GIM","Dim_Regions","Dim_Calendar","Dim_KPI","DemantraDemand","Fact_Sales","Dim_ExitTracker","Fact_Inventory","Dim_Role","Dim_Phase","Dim_PhaseActivity","Fact_TaskAssignments","Fact_E&O"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation __TEdtr = 1

annotation PBI_ProTooling = ["WebModelingEdit","TMDLView_Desktop","DaxQueryView_Desktop","DevMode","TMDL-Extension","MCP-PBIModeling"]

ref table _KPI
ref table Product
ref table Calendar
ref table Region
ref table _Measures
ref table Sales
ref table Inventory
ref table 'Exit Tracker'
ref table _Budget
ref table Role
ref table Phase
ref table 'Phase Activity'
ref table 'Task Assignment'
ref table '_Playbook Navigation'
ref table 'Excess and Obsolete'

ref cultureInfo en-US

