model Model
	defaultMode: directQuery
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Calendar

	annotation PBI_QueryGroupOrder = 0

queryGroup Inventory

	annotation PBI_QueryGroupOrder = 3

queryGroup Sales/Demand

	annotation PBI_QueryGroupOrder = 4

queryGroup 'PLCM RACI Playbook'

	annotation PBI_QueryGroupOrder = 5

queryGroup Products

	annotation PBI_QueryGroupOrder = 4

annotation PBI_QueryOrder = ["Historical Sales","LCC_Description","PPR Tracker Status","Anaplan Products","Dim_GIM","Dim_Regions","Dim_Calendar","Dim_KPI","DemantraDemand","Fact_Sales","Fact_ConsolidatedList","Fact_Inventory","Dim_Role","Dim_Phase","Dim_PhaseActivity","Fact_TaskAssignments","Fact_E&O"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation __TEdtr = 1

annotation PBI_ProTooling = ["WebModelingEdit","TMDLView_Desktop","DaxQueryView_Desktop","DevMode","TMDL-Extension"]

ref table Dim_KPI
ref table Dim_GIM
ref table Dim_Calendar
ref table Dim_Regions
ref table _Measures
ref table Fact_Sales
ref table Fact_Inventory
ref table Fact_ConsolidatedList
ref table Budget
ref table Dim_Role
ref table Dim_Phase
ref table Dim_PhaseActivity
ref table Fact_TaskAssignments
ref table 'Playbook Navigation'
ref table Fact_E&O

ref cultureInfo en-US

