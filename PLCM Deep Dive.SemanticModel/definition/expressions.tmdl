expression 'PPR Tracker Status' = ```
		let
		    // 🔹 Combine the individual tracker tables into one unified table
		    Source = Table.Combine({
		        #"Bio Tracker",
		        #"F&A Tracker",
		        #"Trauma Tracker",
		        #"UE Tracker"
		    }),
		
		    // 🔹 Set explicit and consistent column data types
		    TypedColumns = Table.TransformColumnTypes(Source, {
		        {"PLCM Status", type text},
		        {"SubBrand", type text},
		        {"APAC", type number},
		        {"Canada", type number},
		        {"EEMEA", type number},
		        {"Europe", type number},
		        {"LATAM", type number},
		        {"Global PLCM Decision", type text},
		        {"Roadmap Updated", type text},
		        {"Brand or SKU", type text},
		        {"Deep Dive Data Collected", type text},
		        {"Last Buy", type date},
		        {"Last Sell", type date},
		        {"MDR Remediated?", type text},
		        {"Financial Impact of Global Decision ($)", type text},
		        {"Comments", type text},
		        {"Business Unit", type text},
		        {"US PLCM Decision", type text},
		        {"EU PLCM Decision", type text},
		        {"ASPAC PLCM Decision", type text}
		    }),
		
		    // 🔹 Remove unwanted summary and total rows
		    RemovedGrandTotal = Table.SelectRows(TypedColumns, each [Brand] <> "Grand Total"),
		    RemovedBrandTotal = Table.SelectRows(RemovedGrandTotal, each [#"Brand Total Row?"] = null),
		    FilteredGlobalDecision = Table.SelectRows(RemovedBrandTotal, each [#"Global PLCM Decision"] <> ""),
		
		    // 🔹 Duplicate 'PLCM Status' column for use in executive summary visuals
		    AddedExecSummaryStatus = Table.DuplicateColumn(
		        FilteredGlobalDecision, 
		        "PLCM Status", 
		        "PLCM Status - Exec Summary"
		    ),
		
		    // 🔹 Standardize values in Brand and SubBrand columns
		    StandardizedBrand = Table.ReplaceValue(AddedExecSummaryStatus, "SYK Other", "Other", Replacer.ReplaceText, {"Brand"}),
		    StandardizedBrand_OEM = Table.ReplaceValue(StandardizedBrand, "OEM_SYK", "OEM", Replacer.ReplaceText, {"Brand"}),
		    StandardizedBrand_WM = Table.ReplaceValue(StandardizedBrand_OEM, "WM Other", "Other", Replacer.ReplaceText, {"Brand"}),
		    CleanedBrandSymbols = Table.ReplaceValue(StandardizedBrand_WM, "®", "", Replacer.ReplaceText, {"Brand"}),
		    CleanedSubBrandSymbols = Table.ReplaceValue(CleanedBrandSymbols, "™", "", Replacer.ReplaceText, {"SubBrand"}),
		
		    // 🔹 Normalize Business Unit naming
		    StandardizedBusinessUnit = Table.ReplaceValue(
		        CleanedSubBrandSymbols, 
		        "Foot & Ankle", 
		        "Foot and Ankle", 
		        Replacer.ReplaceText, 
		        {"Business Unit"}
		    ),
		
		    // 🔹 Normalize status naming for executive summary use
		    NormalizedExecSummaryStatus = Table.ReplaceValue(
		        StandardizedBusinessUnit,
		        "Global Roadmap Updated",
		        "Complete - Strategic Decision",
		        Replacer.ReplaceText,
		        {"PLCM Status - Exec Summary"}
		    ),
		
		    // 🔹 Remove unnecessary or intermediate columns
		    RemovedUnnecessaryColumns = Table.RemoveColumns(NormalizedExecSummaryStatus, {
		        "Brand Total Row?",
		        "Group f/ Formatting",
		        "APAC",
		        "Canada",
		        "EEMEA",
		        "Europe",
		        "LATAM",
		        "Brand or SKU",
		        "Deep Dive Data Collected",
		        "MDR Remediated?",
		        "Financial Impact of Global Decision ($)",
		        "Roadmap Updated"
		    }),
		
		    // 🔹 Add a composite key for deduplication and analysis
		    AddedCompositeKey = Table.AddColumn(
		        RemovedUnnecessaryColumns, 
		        "PL_Brand_SubBrand_Key", 
		        each Text.Upper([Business Unit] & [Brand] & [SubBrand]), 
		        type text
		    ),
		
		    // 🔹 Remove duplicate entries based on the composite key
		    DeduplicatedRows = Table.Distinct(AddedCompositeKey, {"PL_Brand_SubBrand_Key"}),
		
		    // 🔹 Rename columns for semantic model clarity
		    RenamedColumns = Table.RenameColumns(DeduplicatedRows, {
		        {"Global PLCM Decision", "Global PLCM Decision (SubBrand)"}
		    }),
		
		    // 🔹 Replace any date conversion errors with null values
		    CleanedDateErrors = Table.ReplaceErrorValues(RenamedColumns, {
		        {"Last Buy", null},
		        {"Last Sell", null}
		    })
		in
		    CleanedDateErrors
		```
