expression 'Bio Tracker' = ```
		let
		    // Source data from the specified Excel file on SharePoint
		    Source = Excel.Workbook(
		        Web.Contents("https://stryker.sharepoint.com/sites/TEPLCM/Shared%20Documents/General/PLCM%20Roadmap,%20Tracker,%20and%20PowerBI%20tools/PLCM%20Tracker_LIVE.xlsx"), 
		        null, 
		        true
		    ),
		
		    // Extract the "Bio Tracker" sheet
		    BioTrackerSheet = Source{[Item="Bio Tracker", Kind="Sheet"]}[Data],
		
		    // Promote the first row as headers
		    PromotedHeaders = Table.PromoteHeaders(
		        BioTrackerSheet, 
		        [PromoteAllScalars = true]
		    ),
		
		    // Change column types for consistency and accuracy
		    ChangedType = Table.TransformColumnTypes(
		        PromotedHeaders, {
		            {"Brand Total Row?", type text}, 
		            {"SYK/WM", type text}, 
		            {"Brand", type text}, 
		            {"SubBrand", type any}, 
		            {"US", type number}, 
		            {"OUS", type number}, 
		            {"Grand Total", type number}, 
		            {"PLCM Status", type text}, 
		            {"Global PLCM Decision", type any}, 
		            {"Roadmap Updated", type any}, 
		            {"Brand or SKU", type any}, 
		            {"Deep Dive Data Collected", type any}, 
		            {"Last Buy", type any}, 
		            {"Last Sell", type any}, 
		            {"MDR Remediated?", type any}, 
		            {"Comments", type any}
		        }
		    ),
		
		    // Remove blank rows by checking if all columns are empty
		    RemovedBlankRows = Table.SelectRows(
		        ChangedType, 
		        each not List.IsEmpty(List.RemoveMatchingItems(Record.FieldValues(_), {"", null}))
		    ),
		
		    // Add a custom column for "Business Unit" with a constant value
		    AddedCustom = Table.AddColumn(
		        RemovedBlankRows, 
		        "Business Unit", 
		        each "Biologics"
		    ),
		
		    // Remove unnecessary columns to optimize the dataset
		    RemovedColumns = Table.RemoveColumns(
		        AddedCustom, 
		        {"US", "OUS", "Grand Total"}
		    )
		in
		    RemovedColumns
		```
