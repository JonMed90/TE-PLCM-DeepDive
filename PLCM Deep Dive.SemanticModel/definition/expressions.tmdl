expression Scenario = ```
		let
		    // Source data from a compressed binary string
		    Source = Table.FromRows(
		        Json.Document(
		            Binary.Decompress(
		                Binary.FromText(
		                    "i45WckwuKU3MUdJRMgBiR2elWJ1oJbf8otTkxOISoIghELsBRWMB", 
		                    BinaryEncoding.Base64
		                ), 
		                Compression.Deflate
		            )
		        ), 
		        let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Target = _t, Index = _t, #"Target 2" = _t]
		    ),
		
		    // Change the type of the "Index" column to Int64
		    ChangedType = Table.TransformColumnTypes(
		        Source, 
		        {{"Index", Int64.Type}}
		    ),
		
		    // Reorder the columns for better readability
		    ReorderedColumns = Table.ReorderColumns(
		        ChangedType, 
		        {"Target 2", "Target", "Index"}
		    ),
		
		    // Rename the "Target 2" column to "Target ABBR"
		    RenamedColumns = Table.RenameColumns(
		        ReorderedColumns, 
		        {{"Target 2", "Target ABBR"}}
		    )
		in
		    RenamedColumns
		```
