/// Actual sales transactions sourced from the Fact_Sales_Summary dataflow entity. Pass-through query combined with DemantraDemand in the Sales table.
expression 'Historical Sales' =
		// Historical Sales — Actual sales transactions (Scenario = AC).
		// Source: Power BI Dataflow > Fact_Sales_Summary entity
		// Pass-through query; no transformations needed.
		// Combined with DemantraDemand in the Sales table query.
		let
		    // ── Connect to dataflow ──
		    Source = PowerPlatform.Dataflows( null ),
		    Workspaces = Source{[Id = "Workspaces"]}[Data],
		    Workspace = Workspaces{[workspaceId = "f4ac28b7-50fc-4635-87fe-7bd77e9652a8"]}[Data],
		    Dataflow = Workspace{[dataflowId = "19ac5c01-6afb-4ed0-8749-bf98aafc6f61"]}[Data],
		    RawSales = Dataflow{[entity = "Fact_Sales_Summary", version = ""]}[Data]
		in
		    RawSales
	lineageTag: 126a7597-9934-4d10-96e9-d9bdb9f09f34
	queryGroup: Sales/Demand

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

/// Forecast demand data sourced from the DemantraCloud dataflow. Renames to match Sales schema, adds Scenario = FC, calculates COGS, groups to monthly grain, and removes zero-value rows.
expression DemantraDemand =
		// DemantraDemand — Forecast demand data (Scenario = FC).
		// Source: Power BI Dataflow > DemantraCloud Dataflow entity
		// Renames source columns, adds Scenario = FC, calculates COGS from
		// manufacturing cost * quantity, groups to monthly grain, and removes
		// zero-value rows to reduce model size.
		let
		    // ── Connect to dataflow ──
		    Source = PowerPlatform.Dataflows( null ),
		    Workspaces = Source{[Id = "Workspaces"]}[Data],
		    Workspace = Workspaces{[workspaceId = "7370e662-04ab-4255-8e24-48b841511f42"]}[Data],
		    Dataflow = Workspace{[dataflowId = "30b852e0-f844-4ba2-8a8b-19381a50fc06"]}[Data],
		    RawDemantra = Dataflow{[entity = "DemantraCloud Dataflow", version = ""]}[Data],
		
		    // ── Rename source columns to match the Sales schema ──
		    Renamed = Table.RenameColumns(
		        RawDemantra,
		        {
		            {"sales_date",           "Date"},
		            {"sellingdivision",      "Selling Division"},
		            {"country",              "Country"},
		            {"region",               "Region"},
		            {"item_gim_id",          "ItemId"},
		            {"catalognumber",        "Catalog Number"},
		            {"fcst_df_final_rev",    "Quantity"},
		            {"fcst_df_final_rev_val","Revenue"}
		        }
		    ),
		
		    // ── Add Scenario = FC to identify forecast rows ──
		    AddedScenario = Table.AddColumn(
		        Renamed, "Scenario", each "FC", type text
		    ),
		
		    // ── Calculate COGS from manufacturing cost * quantity ──
		    AddedCOGS = Table.AddColumn(
		        AddedScenario,
		        "COGS",
		        each [manufacturingcostusd] * [Quantity],
		        type number
		    ),
		
		    // ── Group to monthly grain by item, geography, and scenario ──
		    Grouped = Table.Group(
		        AddedCOGS,
		        {"Date", "ItemId", "Catalog Number", "Country", "Region", "Scenario"},
		        {
		            {"Quantity", each List.Sum( [Quantity] ), type nullable number},
		            {"Revenue",  each List.Sum( [Revenue] ),  type nullable number},
		            {"COGS",     each List.Sum( [COGS] ),     type number}
		        }
		    ),
		
		    // ── Remove zero/null rows to reduce model size ──
		    Filtered = Table.SelectRows(
		        Grouped,
		        each not (
		            (Number.From( [Quantity] ) = 0 or [Quantity] = null) and
		            (Number.From( [Revenue] )  = 0 or [Revenue]  = null) and
		            (Number.From( [COGS] )     = 0 or [COGS]     = null)
		        )
		    )
		in
		    Filtered
	lineageTag: cfb8c8bb-3e3d-4373-90de-1cb4bdc99ff1
	queryGroup: Sales/Demand

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

