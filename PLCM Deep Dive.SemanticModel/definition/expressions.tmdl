expression 'Anaplan Products' = ```
		let
		    // Source data from the specified Excel file on SharePoint
		    Source = Excel.Workbook(
		        Web.Contents("https://stryker.sharepoint.com/sites/TEPLCM/Shared%20Documents/General/PLCM%20Roadmap,%20Tracker,%20and%20PowerBI%20tools/PowerBI/v2%20Support/P-HP07%20Item%20%5BHUB%5D.xlsx"), 
		        null, 
		        true
		    ),
		
		    // Extract the "Sheet 1" sheet
		    Sheet1 = Source{[Item = "Sheet 1", Kind = "Sheet"]}[Data],
		
		    // Promote the first row as headers
		    PromotedHeaders = Table.PromoteHeaders(Sheet1, [PromoteAllScalars = true]),
		
		    // Change column types for consistency and accuracy
		    ChangedColumnTypes = Table.TransformColumnTypes(
		        PromotedHeaders, {
		            {"", type text}, 
		            {"Item Number", type text}, 
		            {"Item Description", type text}, 
		            {"Line [Item Class (HPR01)]", type text}, 
		            {"Sales Segment[Item Family Group (HPR02)]", type text}, 
		            {"Sales Family [Item Line Family (HPR03)]", type text}, 
		            {"Brand [Item Line (HPR04)]", type text}, 
		            {"Imp Inst Kits", type text}, 
		            {"Imp Inst Kits Desc", type text}, 
		            {"Master Planning Family", type text}, 
		            {"Stocking Type Code", type text}, 
		            {"Item Grouping", type text}, 
		            {"Inventory UOM", type text}, 
		            {"GIM_ID", Int64.Type}
		        }
		    ),
		
		    // Rename columns for clarity
		    RenamedColumns = Table.RenameColumns(
		        ChangedColumnTypes, {
		            {"Line [Item Class (HPR01)]", "Product Line"}, 
		            {"Sales Segment[Item Family Group (HPR02)]", "Segment"}, 
		            {"Sales Family [Item Line Family (HPR03)]", "Family"}, 
		            {"Brand [Item Line (HPR04)]", "Brand"}, 
		            {"Item Description", "Description"}, 
		            {"Item Grouping", "Franchise"}
		        }
		    ),
		
		    // Add a custom column for normalized item numbers
		    AddedNormalizedItemNumber = Table.AddColumn(
		        RenamedColumns, 
		        "Item_Number_Normalized", 
		        each Text.Select([Item Number], {"0".."9", "A".."z"}), 
		        type text
		    ),
		
		    // Add an index column
		    AddedIndexColumn = Table.AddIndexColumn(
		        AddedNormalizedItemNumber, 
		        "Index", 
		        0, 
		        1, 
		        Int64.Type
		    )
		in
		    AddedIndexColumn
		```
	lineageTag: 41d9d867-af05-4504-91da-63ec42efb4fc
	queryGroup: Products

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

expression 'Historical Sales' = ```
		let
		    // Connect to Power BI Dataflows
		    Source = PowerPlatform.Dataflows(null),
		    Workspaces = Source{[Id="Workspaces"]}[Data],
		    #"f4ac28b7-50fc-4635-87fe-7bd77e9652a8" = Workspaces{[workspaceId="f4ac28b7-50fc-4635-87fe-7bd77e9652a8"]}[Data],
		    #"19ac5c01-6afb-4ed0-8749-bf98aafc6f61" = #"f4ac28b7-50fc-4635-87fe-7bd77e9652a8"{[dataflowId="19ac5c01-6afb-4ed0-8749-bf98aafc6f61"]}[Data],
		    // Access the specific entity (table) within the dataflow
		    #"Sales History_" = #"19ac5c01-6afb-4ed0-8749-bf98aafc6f61"{[entity="Sales History",version=""]}[Data],
		
		    // Add a custom column for the scenario
		    AddedScenarioColumn = Table.AddColumn(
		        #"Sales History_", 
		        "Scenario", 
		        each "AC", 
		        type text
		    ),
		    #"Filtered Rows" = Table.SelectRows(AddedScenarioColumn, each [Date] >= #date(2022, 1, 1)),
		
		    // Add a custom column for the data source
		    AddedSourceColumn = Table.AddColumn(
		        #"Filtered Rows", 
		        "Source", 
		        each "Encompass", 
		        type text
		    ),
		
		    // Merge with the GIM table on "ItemId"
		    MergedGIMData = Table.NestedJoin(AddedSourceColumn, {"ItemId"}, Dim_GIM, {"ItemId"}, "Dim_GIM", JoinKind.Inner),
		
		    // Expand the "ManufacturingcostUSD" column from the nested GIM table
		    ExpandedGIMCost = Table.ExpandTableColumn(MergedGIMData, "Dim_GIM", { "Manufacturing Cost"}, {"Dim_GIM.manufacturingcostusd"}),
		    // Add a custom column for COGS calculation
		    AddedCOGSColumn = Table.AddColumn(
		        ExpandedGIMCost, 
		        "COGS", 
		        each [Quantity] * [Dim_GIM.manufacturingcostusd], Currency.Type
		    ),
		
		    // Remove the expanded column to optimize the dataset
		    RemovedExpandedColumns = Table.RemoveColumns(
		        AddedCOGSColumn, 
		        {"Dim_GIM.manufacturingcostusd"}
		    ),
		
		    // Replace empty values in the "Region" column with "UNKNOWN"
		    ReplacedEmptyRegionValues = Table.ReplaceValue(
		        RemovedExpandedColumns, 
		        "", 
		        "UNKNOWN", 
		        Replacer.ReplaceValue, 
		        {"Region"}
		    )
		in
		    ReplacedEmptyRegionValues
		```
	lineageTag: 126a7597-9934-4d10-96e9-d9bdb9f09f34
	queryGroup: Sales/Demand

