	measure '[_DQ_] Fact_Inventory Unmatched ItemIds' =
			
			COUNTROWS (
			    EXCEPT (
			        DISTINCT ( ALL ( Fact_Inventory[ItemId] ) ),
			        DISTINCT ( ALL ( Dim_GIM[ItemId] ) )
			    )
			)
