	/// VAR UnmatchedRegions =
	/// EXCEPT (
	/// DISTINCT ( ALL ( Fact_Inventory[Region] ) ),
	/// DISTINCT ( ALL ( Dim_Regions[Region] ) )
	/// )
	/// RETURN
	/// COUNTROWS ( FILTER ( ALL ( Fact_Inventory ), Fact_Inventory[Region] IN UnmatchedRegions ) )
	measure '[_DQ_] Fact_Inventory Unmatched Region Rows' =
			
			VAR UnmatchedRegions =
			    EXCEPT (
			        DISTINCT ( ALL ( Fact_Inventory[Region] ) ),
			        DISTINCT ( ALL ( Dim_Regions[Region] ) )
			    )
			RETURN
			    COUNTROWS ( FILTER ( ALL ( Fact_Inventory ), Fact_Inventory[Region] IN UnmatchedRegions ) )
		formatString: #,0
		isHidden
		displayFolder: _DQ_
		lineageTag: d1e2f3a4-b5c6-4789-d012-e34f5a6b7c80

	/// CALCULATE (
	/// COUNTROWS ( Fact_Sales ),
	/// NOT ( Fact_Sales[Scenario] IN { "AC", "FC" } ),
	/// ALL ( Fact_Sales )
	/// )
	measure '[_DQ_] Fact_Sales Invalid Scenario Rows' =
			
			CALCULATE (
			    COUNTROWS ( Fact_Sales ),
			    NOT ( Fact_Sales[Scenario] IN { "AC", "FC" } ),
			    ALL ( Fact_Sales )
			)
		formatString: #,0
		isHidden
		displayFolder: _DQ_
		lineageTag: e1f2a3b4-c5d6-4789-e012-f34a5b6c7d80

	/// VAR TotalRows = COUNTROWS ( ALL ( Fact_Sales ) )
	/// VAR NullRows =
	/// COUNTROWS (
	/// FILTER ( ALL ( Fact_Sales ), ISBLANK ( Fact_Sales[Dim_Regions.Index] ) )
	/// )
	/// RETURN DIVIDE ( NullRows, TotalRows )
	measure '[_Metrics_] % Fact_Sales Null Region' =
			
			VAR TotalRows = COUNTROWS ( ALL ( Fact_Sales ) )
			VAR NullRows =
			    COUNTROWS (
			        FILTER ( ALL ( Fact_Sales ), ISBLANK ( Fact_Sales[Dim_Regions.Index] ) )
			    )
			RETURN
			    DIVIDE ( NullRows, TotalRows )
		formatString: 0.00%;-0.00%;0.00%
		isHidden
		displayFolder: _Metrics_
		lineageTag: f1a2b3c4-d5e6-4789-f012-a34b5c6d7e80

