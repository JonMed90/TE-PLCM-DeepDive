	measure Revenue = ```
			SUM(Fact_Sales[Revenue])
				
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: e6205c9f-7019-47f1-a963-2b2c9761fd04

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'TTM COGS' = ```
			SUMX(
						Dim_GIM,
						[TTM Units] * Dim_GIM[Manufacturing Cost]
					)
				
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: a413169c-b97e-4a48-90fd-5e8b2841c584

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'TTM Revenue' = ```
			VAR EndDate =
					CALCULATE(
						MAX(Fact_Sales[Date]),
						ALL(),
						Fact_Sales[Scenario] = "AC"
					) --retrives Max Date
					VAR StartDate =
					EDATE(
						EndDate,
						-12
					) + 1 -- Shifts EndDate to date beginning
					RETURN
						CALCULATE(
							[Revenue],
							FILTER(
								'Dim_Calendar',
								'Dim_Calendar'[Date] >= StartDate
								&& 'Dim_Calendar'[Date] <= EndDate
							)
						)
				
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: b9edf60d-9d37-4940-aedc-8078ac5fddfd

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'TTM Units' = ```
			
			VAR EndDate =
			CALCULATE(
			    MAX(Fact_Sales[Date]),
			    ALL(),
			    Fact_Sales[Scenario] = "AC"
			) --retrives last date of actual sales
			VAR StartDate =
			EDATE(
			    EndDate,
			    -12
			) + 1 -- Shifts EndDate to date beginning
			RETURN
			    CALCULATE(
			        [Units Sold],
			        FILTER(
			            'Dim_Calendar',
			            'Dim_Calendar'[Date] >= StartDate
			            && 'Dim_Calendar'[Date] <= EndDate
			        )
			    )
				
			```
		formatString: #,0
		lineageTag: 81c65ac1-0ecc-4233-8109-25f176195073

		changedProperty = FormatString

	measure 'Units Sold' = ```
			SUM(Fact_Sales[Quantity])
				
			```
		formatString: #,0
		lineageTag: 5caa14ff-a22d-4c0c-8087-ec4bf483eb72

		changedProperty = FormatString

	measure 'TTM Start Date' = ```
			VAR EndDate =
					CALCULATE(
						MAX(Fact_Sales[Date]),
						ALL(),
						Fact_Sales[Scenario] = "AC"
					) --retrives last date of actual sales
					VAR StartDate =
					EDATE(
						EndDate,
						-12
					) + 1 -- Shifts EndDate to date beginning
					RETURN
						StartDate
				
			```
		formatString: General Date
		displayFolder: Text Box Measures
		lineageTag: 5b07bd4f-5e65-4864-802e-30c386966ace

	measure 'TTM End Date' =
			VAR EndDate =
					CALCULATE(
						MAX(Fact_Sales[Date]),
						ALL(),
						Fact_Sales[Scenario] = "AC"
					) --retrives last date of actual sales
					RETURN
						EndDate
		formatString: General Date
		displayFolder: Text Box Measures
		lineageTag: 9acbf14c-6718-40d5-96a4-a96c62656660

	measure '# GIM SKUs' = DISTINCTCOUNT(Dim_GIM[ItemId])
		formatString: #,0
		lineageTag: dac12fbc-ab6a-485b-945e-212130a9f9e3

	measure 'Actual Sales - End Date' = ```
			VAR StartingMonth =
					CALCULATE(
						MAX(Fact_Sales[Date]),
						ALL(),
						Fact_Sales[Scenario] = "AC"
					) --Retrieves forecast starting date
					VAR DayinMonth =
					DAY(StartingMonth) --Day of Month
					RETURN
						--StartingMonth - ( DayinMonth )
						-- removing number of days to get previous month ending date (e.g., if starting date is 4/30/2022, then 4/30/2022 - 30 days = 3/31/2022 )
						StartingMonth
				
			```
		formatString: General Date
		displayFolder: Text Box Measures
		lineageTag: 3118f39c-b627-4878-b9f7-89fca6216987

	measure 'Actual Sales - Start Date' =
			CALCULATE(
						MIN(Fact_Sales[Date]),
						ALL(),
						Fact_Sales[Scenario] = "AC"
					)
		formatString: General Date
		displayFolder: Text Box Measures
		lineageTag: 9b1d29e6-9424-421d-84de-0dc6af0b15a8

	measure 'Forecast Sales - End Date' = ```
			CALCULATE(
						MAX(Fact_Sales[Date]),
						ALL(),
						Fact_Sales[Scenario] = "FC"
					)
				
			```
		formatString: General Date
		displayFolder: Text Box Measures
		lineageTag: 983b29ad-3c4d-4462-a2b8-795a7643402d

	measure 'Forecast Sales - Start Date' =
			VAR StartingMonth =
					CALCULATE(
						MIN(Fact_Sales[Date]),
						ALL(),
						Fact_Sales[Scenario] = "FC"
					) --Retrieves forecast starting date
					VAR DayinMonth =
					DAY(StartingMonth) --Day of Month
					RETURN
						StartingMonth - (DayinMonth - 1)
		formatString: General Date
		displayFolder: Text Box Measures
		lineageTag: 6eee2923-6697-490e-95bd-ad5aae29384e

	measure 'Dynamic Sales KPI Selection' = SELECTEDVALUE('Dim_KPI'[KPI])
		lineageTag: 622f9b9a-2ca3-41fd-bfcb-3a84418e476f

	measure 'Gross Profit' = ```
			
			 [Trailing 12M Revenue]-[COGS]
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 49aa30ea-bd26-4e58-ab20-e56c161b1e4e

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Trailing 12M Revenue' =
			
			VAR MaxSalesDate = EOMONTH( TODAY(), -1)
			RETURN
			    CALCULATE(
			        [Revenue],
			        DATESINPERIOD(
			            'Dim_Calendar'[Date],
			            MaxSalesDate,
			            -12,
			            MONTH
			        )
			    )
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 25abd72d-e1dd-4d6b-a936-f1c409a00661

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Profit Margin' =
			
			DIVIDE([Gross Profit], [Trailing 12M Revenue])
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 738d0342-3dca-46b0-848d-42306c5fb5a8

	measure 'Profit Margin minus Sum of Budgeted Growth Margin' =
			
			[Profit Margin] - [Budget Growth Margin %]
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 99608302-db59-4f39-b772-e391f1fc7d42

	measure 'Next 12M Demand Units' = ```
			
			VAR StartDate =
			    DATE ( YEAR ( TODAY() ), MONTH ( TODAY() ), 1 )
			VAR EndDate =
			    EDATE ( StartDate, 11 )
			RETURN
			    CALCULATE (
			        [Units Sold],
			        DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate )
			    )
			
			```
		formatString: #,0
		lineageTag: acea76f7-9c01-49f5-a981-9dc066e45542

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Ext Management Cost' = SUM(Fact_Inventory[ERP_Extended_Management_Cost_USD])
