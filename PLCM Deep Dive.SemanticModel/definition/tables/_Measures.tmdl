	/// COUNTROWS ( Dim_GIM ) - DISTINCTCOUNT ( Dim_GIM[ItemId] )
	measure '[_DQ_] Dim_GIM Duplicate ItemIds' =
			
			COUNTROWS ( Dim_GIM ) - DISTINCTCOUNT ( Dim_GIM[ItemId] )
		formatString: #,0
		isHidden
		displayFolder: _DQ_
		lineageTag: a1b2c3d4-e5f6-4789-a012-b34c5d6e7f80

	/// COUNTROWS (
	/// EXCEPT (
	/// DISTINCT ( ALL ( Fact_Sales[ItemId] ) ),
	/// DISTINCT ( ALL ( Dim_GIM[ItemId] ) )
	/// )
	/// )
	measure '[_DQ_] Fact_Sales Unmatched ItemIds' =
			
			COUNTROWS (
			    EXCEPT (
			        DISTINCT ( ALL ( Fact_Sales[ItemId] ) ),
			        DISTINCT ( ALL ( Dim_GIM[ItemId] ) )
			    )
			)
		formatString: #,0
		isHidden
		displayFolder: _DQ_
		lineageTag: b1c2d3e4-f5a6-4789-b012-c34d5e6f7a80

	/// COUNTROWS (
	/// EXCEPT (
	/// DISTINCT ( ALL ( Fact_Inventory[ItemId] ) ),
	/// DISTINCT ( ALL ( Dim_GIM[ItemId] ) )
	/// )
