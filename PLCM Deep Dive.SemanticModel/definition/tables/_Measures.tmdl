	measure '# ConsolidatedList SKUs' = COUNTROWS('Fact_ConsolidatedList')
		formatString: #,0
		lineageTag: 720b927f-c470-414e-a6a5-5a16eeec0df0

		changedProperty = IsHidden

	measure 'DSI (COGS)' = ```
			DIVIDE(
						[Ext Statutory Cost],
						[TTM COGS]
					) * 365
				
			```
		formatString: #,0
		lineageTag: bf3ab89d-9135-4648-966a-647678351a20

		changedProperty = FormatString

	measure 'Dynamic Global PLCM Decision' = ```
			VAR Brand =
					SELECTEDVALUE(Dim_GIM[Global PLCM Decision (Brand)])
					VAR SubBrand =
					SELECTEDVALUE(Dim_GIM[Global PLCM Decision (SubBrand)])
					RETURN
						IF(
							ISINSCOPE(Dim_GIM[SubBrand]),
							SubBrand,
							Brand
						)
				
			```
		lineageTag: 33d54d86-362f-4716-bfe1-d81d5dddb9c9

	measure 'Dynamic Sales KPI' = ```
			VAR SelectedKPI =
					SELECTEDVALUE('Dim_KPI'[KPI])
					RETURN
						SWITCH(
							TRUE(),
							SelectedKPI = "Revenue", [Revenue],
							SelectedKPI = "Units", [Units Sold],
							SelectedKPI = "COGS", [COGS]
						)
					
			```
		formatString: #,0
		lineageTag: d2ac9558-2e93-4299-bbd1-53705af0c1b1

		changedProperty = FormatString

		annotation PBI_FormatHint = {"isDecimal":true}

	measure 'Inventory QoH' = ```
			SUM(Fact_Inventory[QuantityOnHand])
				
			```
		formatString: #,0
		lineageTag: 8ca778fb-6cd8-4952-8305-a855c6053d81

		changedProperty = FormatString

	measure 'Ext Statutory Cost' = ```
			SUM(Fact_Inventory[ERP_Extended_Statutory_Cost_USD])
				
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: aec56f89-743d-4d6d-b158-9f62429a16d6

		changedProperty = FormatString

