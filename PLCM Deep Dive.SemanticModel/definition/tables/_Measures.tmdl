	/// [Revenue] - [COGS]
	measure 'Gross Profit' =
			
			[Revenue] - [COGS]
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Profitability
		lineageTag: 49aa30ea-bd26-4e58-ab20-e56c161b1e4e

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// DIVIDE ( [Gross Profit], [Revenue] )
	measure 'Profit Margin' =
			
			DIVIDE ( [Gross Profit], [Revenue] )
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Profitability
		lineageTag: 738d0342-3dca-46b0-848d-42306c5fb5a8

	/// IF (
	/// ISBLANK ( [Revenue] ) || [Revenue] = 0,
	/// BLANK (),
	/// [Profit Margin] - [Budget Growth Margin %]
	/// )
	measure 'Profit Margin minus Sum of Budgeted Growth Margin' =
			
			IF (
			    ISBLANK ( [Revenue] ) || [Revenue] = 0,
			    BLANK (),
			    [Profit Margin] - [Budget Growth Margin %]
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Profitability
		lineageTag: 99608302-db59-4f39-b772-e391f1fc7d42

	/// VAR StartDate =
	/// CALCULATE ( MIN ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "FC" ) --retrieves last date of actual sales
	/// VAR EndDate =
	/// EDATE ( StartDate, 12 ) - 1 -- Shifts EndDate to date beginning
	/// RETURN
	/// CALCULATE (
	/// [Units Sold],
	/// DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate )
	/// )
	measure 'Next 12M Demand Units' =
			
			VAR StartDate =
			    CALCULATE ( MIN ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "FC" ) --retrieves last date of actual sales
			VAR EndDate =
			    EDATE ( StartDate, 12 ) - 1 -- Shifts EndDate to date beginning
			RETURN
			    CALCULATE (
			        [Units Sold],
			        DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate )
			    )
		formatString: #,0
		displayFolder: Demand
		lineageTag: acea76f7-9c01-49f5-a981-9dc066e45542

		annotation PBI_FormatHint = {"isDecimal":true}

	/// SUM ( Fact_Inventory[ERP_Extended_Management_Cost_USD] )
	measure 'Ext Management Cost' =
			
			SUM ( Fact_Inventory[ERP_Extended_Management_Cost_USD] )
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Inventory
		lineageTag: c326d1b4-ae0c-4365-b9bb-d8a66a0fd42b

	/// IF (
	/// ISBLANK ( [Revenue] ) || [Revenue] = 0,
	/// BLANK (),
	/// CALCULATE (
	/// SELECTEDVALUE ( Budget[Budgeted %] ),
	/// TREATAS ( VALUES ( Dim_GIM[Business Unit] ), Budget[BU] )
	/// )
	/// )
	measure 'Budget Growth Margin %' =
			
			IF (
			    ISBLANK ( [Revenue] ) || [Revenue] = 0,
			    BLANK (),
			    CALCULATE (
			        SELECTEDVALUE ( Budget[Budgeted %] ),
			        TREATAS ( VALUES ( Dim_GIM[Business Unit] ), Budget[BU] )
			    )
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Profitability
		lineageTag: 606018e5-989b-46a8-baba-07118ff8ab02

