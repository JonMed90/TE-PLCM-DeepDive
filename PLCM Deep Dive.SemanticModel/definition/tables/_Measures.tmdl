	/// VAR EndDate =
	/// CALCULATE ( MAX ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "AC" )
	/// VAR StartDate =
	/// EDATE ( EndDate, -12 ) + 1
	/// RETURN
	/// CALCULATE ( [COGS], DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate ) )
	measure 'TTM COGS' =
			
			VAR EndDate =
			    CALCULATE ( MAX ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "AC" )
			VAR StartDate =
			    EDATE ( EndDate, -12 ) + 1
			RETURN
			    CALCULATE ( [COGS], DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate ) )
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Trailing 12M
		lineageTag: a413169c-b97e-4a48-90fd-5e8b2841c584

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// VAR EndDate =
	/// CALCULATE ( MAX ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "AC" ) --retrieves last date of actual sales
	/// VAR StartDate =
	/// EDATE ( EndDate, -12 ) + 1 -- Shifts EndDate to date beginning
	/// RETURN
	/// CALCULATE (
	/// [Revenue],
	/// DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate )
	/// )
	measure 'TTM Revenue' =
			
			VAR EndDate =
			    CALCULATE ( MAX ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "AC" ) --retrieves last date of actual sales
			VAR StartDate =
			    EDATE ( EndDate, -12 ) + 1 -- Shifts EndDate to date beginning
			RETURN
			    CALCULATE (
			        [Revenue],
			        DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate )
			    )
		formatString: \$#,0;(\$#,0);\$#,0
		displayFolder: Trailing 12M
		lineageTag: b9edf60d-9d37-4940-aedc-8078ac5fddfd

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// VAR EndDate =
	/// CALCULATE ( MAX ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "AC" ) --retrieves last date of actual sales
	/// VAR StartDate =
	/// EDATE ( EndDate, -12 ) + 1 -- Shifts EndDate to date beginning
	/// RETURN
	/// CALCULATE (
	/// [Units Sold],
	/// DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate )
	/// )
	measure 'TTM Units' =
			
			VAR EndDate =
			    CALCULATE ( MAX ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "AC" ) --retrieves last date of actual sales
			VAR StartDate =
			    EDATE ( EndDate, -12 ) + 1 -- Shifts EndDate to date beginning
			RETURN
			    CALCULATE (
			        [Units Sold],
			        DATESBETWEEN ( 'Dim_Calendar'[Date], StartDate, EndDate )
			    )
		formatString: #,0
		displayFolder: Trailing 12M
		lineageTag: 81c65ac1-0ecc-4233-8109-25f176195073

		changedProperty = FormatString

