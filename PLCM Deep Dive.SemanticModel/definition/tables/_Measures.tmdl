	/// VAR StartingMonth =
	/// CALCULATE ( MIN ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "FC" )
	/// RETURN
	/// DATE ( YEAR ( StartingMonth ), MONTH ( StartingMonth ), 1 )
	measure 'Forecast Sales - Start Date' =
			
			VAR StartingMonth =
			    CALCULATE ( MIN ( Fact_Sales[Date] ), ALL (), Fact_Sales[Scenario] = "FC" )
			RETURN
			    DATE ( YEAR ( StartingMonth ), MONTH ( StartingMonth ), 1 )
		formatString: General Date
		displayFolder: Demand
