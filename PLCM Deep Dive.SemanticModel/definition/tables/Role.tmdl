/// Department roles used in RACI task assignment for PLCM phaseout activities.
table Role
	lineageTag: 2ef32677-9173-411c-82da-8569d82727dd

	/// Department role name used in RACI assignments.
	column 'Role Name'
		dataType: string
		lineageTag: e510733c-0a1e-4318-b92c-51f2c9435c94
		summarizeBy: none
		sourceColumn: Role Name

		annotation SummarizationSetBy = Automatic

	partition Dim_Role = m
		mode: import
		queryGroup: 'PLCM RACI Playbook'
		source =
				// Role — Department role lookup for RACI assignments.
				// Source: Power BI Dataflow > dim_Role entity
				// Pass-through query; no transformations needed.
				let
				    // ── Connect to PLCM RACI dataflow ──
				    Source = PowerPlatform.Dataflows( null ),
				    Workspaces = Source{[Id = "Workspaces"]}[Data],
				    Workspace = Workspaces{[workspaceId = "7e9a6bda-7b19-48ec-ac34-1f7d14deda8c"]}[Data],
				    Dataflow = Workspace{[dataflowId = "1830a663-42fe-4d9a-bc4b-93a6ae5df183"]}[Data],
				    RawRole = Dataflow{[entity = "dim_Role", version = ""]}[Data]
				in
				    RawRole

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

