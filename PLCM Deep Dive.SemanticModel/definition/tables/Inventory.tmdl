	partition Fact_Inventory-b128650f-cd9b-485e-a6c7-709f0d42cfbe = m
		mode: import
		queryGroup: Inventory
		source =
				// Inventory — Finished goods inventory positions.
				// Source: Power BI Dataflow > fact_Inventory_FG_Summary entity
				// Joins to Region lookup for the integer FK, then drops the text Region column.
				let
				    // ── Connect to dataflow ──
				    Source = PowerPlatform.Dataflows( null ),
				    Workspaces = Source{[Id = "Workspaces"]}[Data],
				    Workspace = Workspaces{[workspaceId = "f4ac28b7-50fc-4635-87fe-7bd77e9652a8"]}[Data],
				    Dataflow = Workspace{[dataflowId = "41f287c8-3350-4c8e-996a-5a6f9956999c"]}[Data],
				    RawInventory = Dataflow{[entity = "fact_Inventory_FG_Summary", version = ""]}[Data],
				
				    // ── Join to Region lookup for integer FK ──
				    JoinedRegion = Table.NestedJoin(
				        RawInventory,
				        {"Region"},
				        Region,
				        {"Region"},
				        "Region.Lookup",
				        JoinKind.LeftOuter
				    ),
				    ExpandedRegion = Table.ExpandTableColumn(
				        JoinedRegion,
				        "Region.Lookup",
				        {"Index"},
				        {"Dim_Regions.Index"}
				    ),
				
				    // ── Drop text Region column (FK replaces it) ──
				    Cleaned = Table.RemoveColumns( ExpandedRegion, {"Region"} )
				in
				    Cleaned

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

